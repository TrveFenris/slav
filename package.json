{
  "name": "you-are-slav",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "main": "index.tsx",
  "dependencies": {
    "react": "17.0.2",
    "react-dom": "17.0.2"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "7.20.7",
    "@babel/preset-env": "7.29.2",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@types/react": "17.0.91",
    "@types/react-dom": "17.0.26",
    "babel-loader": "8.4.1",
    "clean-webpack-plugin": "4.0.0",
    "css-loader": "5.2.7",
    "html-webpack-plugin": "5.6.6",
    "prettier": "2.8.8",
    "source-map-loader": "2.0.2",
    "style-loader": "2.0.0",
    "ts-loader": "9.5.4",
    "typescript": "4.9.5",
    "url-loader": "4.1.1",
    "webpack": "5.105.4",
    "webpack-cli": "4.10.0",
    "webpack-dev-server": "5.2.3",
    "webpack-merge": "5.10.0"
  },
  "scripts": {
    "start": "webpack serve --env NODE_ENV=development --config webpack.config.js --open --hot",
    "build": "webpack --env NODE_ENV=production --env production --config webpack.config.js",
    "check-types": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.+(ts|tsx|js|jsx|css)\"",
    "check-format": "prettier --check \"src/**/*.+(ts|tsx|js|jsx|css)\""
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
